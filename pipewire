# restart pipewire service
systemctl --user restart pipewire

# list sound cards on machine
pactl list cards short

# list attached audio devices
pactl list sinks short

# list attached audio devices in detail
pactl list sinks

# see loaded modules
pactl list modules

# unmute audio devices
# where sink name can be obtained from pactl list sinks
pactl set-sink-mute <sink_name> 0

# see list of sinks and sources
wpctl status

# restart all associated services
systemctl --user restart wireplumber pipewire pipewire-pulse
sudo systemctl restart bluetooth
